#!/usr/bin/env bash
# open-jersey-db pre-commit gate — this repo is PUBLIC.
# Blocks staged secrets / affiliate data / internal hosts before they are committed.
# Enable once per clone:  git config core.hooksPath .githooks
set -euo pipefail
files=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$files" ] && exit 0
# shellcheck disable=SC2086
python3 scripts/check_safety.py $files
